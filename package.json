{
  "name": "@pedrohrferreira/rods-sdk",
  "version": "0.1.11",
  "description": "Agent governance framework with Context Engine retrieval and RTK-first token economy.",
  "type": "module",
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "bin": {
    "rods": "bin/rods",
    "context": "bin/context",
    "context-mcp": "bin/context-mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PedroHRFerreira/rods-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/PedroHRFerreira/rods-sdk/issues"
  },
  "homepage": "https://github.com/PedroHRFerreira/rods-sdk#readme",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "dev": "tsx src/cli.ts",
    "dev:mcp": "tsx src/mcp/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "better-sqlite3": "^11.8.1",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.3",
    "ora": "^8.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
